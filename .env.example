# ---- Postgres (данные проекта) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=casino
POSTGRES_PORT=5432

# ---- Метаданные Airflow (отдельная БД в том же Postgres) ----
AIRFLOW_DB_PASSWORD=airflow

# ---- Airflow UI ----
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Fernet-ключ для шифрования connections/variables в Airflow.
# Сгенерировать свой: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# UID для прав на смонтированные тома (Mac/Linux). На Windows игнорируется.
# Mac/Linux: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# ---- Metabase ----
METABASE_PORT=3000
# Авто-создаваемый админ Metabase (provision.py). Пароль должен быть «сложным»,
# иначе Metabase его отклонит.
MB_ADMIN_EMAIL=admin@example.com
MB_ADMIN_PASSWORD=Metabase123!
